# Server
PORT=3000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/hubspot_pylon

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# HubSpot
# Private app access token (Settings > Integrations > Private Apps)
HUBSPOT_ACCESS_TOKEN=pat-na1-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Client secret from your app (used to verify webhook signatures)
HUBSPOT_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# HubSpot Deal Pipeline & Stage IDs
# Run `npm run hs:stages` to print all pipeline and stage IDs for your account
HUBSPOT_PIPELINE_ID=
HUBSPOT_STAGE_READY_TO_QUOTE=
HUBSPOT_STAGE_QUOTE_SENT=
HUBSPOT_STAGE_CLOSED_WON=

# Pylon
# Bearer token from Pylon Settings > API
PYLON_API_TOKEN=
# Optional: shared secret if Pylon adds signature headers in future
PYLON_WEBHOOK_SECRET=
